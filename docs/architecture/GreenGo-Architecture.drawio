        <mxCell id="master-c850" value="3. txn: coinBalances/{uid} ⟵ camelCase model ONLY" style="rounded=1;arcSize=30;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#9E9E9E;fontColor=#263238;strokeColor=#AD1457;" vertex="1" parent="master-m847"><mxGeometry x="9" y="89" width="400" height="22" as="geometry"/></mxCell>
        <mxCell id="master-c851" value="4. coinTransactions/{id} audit row" style="rounded=1;arcSize=30;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#9E9E9E;fontColor=#263238;strokeColor=#AD1457;" vertex="1" parent="master-m847"><mxGeometry x="9" y="116" width="400" height="22" as="geometry"/></mxCell>
        <mxCell id="master-c852" value="5. spend path → tier_limits_service + usage_limit_service" style="rounded=1;arcSize=30;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#9E9E9E;fontColor=#263238;strokeColor=#AD1457;" vertex="1" parent="master-m847"><mxGeometry x="9" y="143" width="400" height="22" as="geometry"/></mxCell>
        <mxCell id="master-c853" value="6. giftCoins → coinGifts + notification + push" style="rounded=1;arcSize=30;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#9E9E9E;fontColor=#263238;strokeColor=#AD1457;" vertex="1" parent="master-m847"><mxGeometry x="9" y="170" width="400" height="22" as="geometry"/></mxCell>
        <mxCell id="master-m854" value="③ INGEST EXTERNAL EVENT" style="swimlane;html=1;rounded=1;arcSize=4;startSize=24;fontSize=11;fontStyle=1;fillColor=#FFFFFF;strokeColor=#9E9E9E;fontColor=#263238;swimlaneFillColor=#FFFFFF;collapsible=1;startSize=26;" vertex="1" parent="master-g839"><mxGeometry x="882" y="44" width="418" height="201" as="geometry"><mxRectangle x="882" y="44" width="260" height="44" as="alternateBounds"/></mxGeometry></mxCell>
        <mxCell id="master-c855" value="1. Scheduler (pub/sub cron) → ingestExternalEvents" style="rounded=1;arcSize=30;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#9E9E9E;fontColor=#263238;strokeColor=#1565C0;" vertex="1" parent="master-m854"><mxGeometry x="9" y="35" width="400" height="22" as="geometry"/></mxCell>
        <mxCell id="master-c856" value="2. per-source adapters: Viator · Ticketmaster · Tiqets · Geoapify" style="rounded=1;arcSize=30;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#9E9E9E;fontColor=#263238;strokeColor=#1565C0;" vertex="1" parent="master-m854"><mxGeometry x="9" y="62" width="400" height="22" as="geometry"/></mxCell>
        <mxCell id="master-c857" value="3. normalise → external_events/{id} (+ geohash)" style="rounded=1;arcSize=30;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#9E9E9E;fontColor=#263238;strokeColor=#1565C0;" vertex="1" parent="master-m854"><mxGeometry x="9" y="89" width="400" height="22" as="geometry"/></mxCell>
        <mxCell id="master-c858" value="4. runBuildExternalIndexNow → external_events_index shards" style="rounded=1;arcSize=30;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#9E9E9E;fontColor=#263238;strokeColor=#1565C0;" vertex="1" parent="master-m854"><mxGeometry x="9" y="116" width="400" height="22" as="geometry"/></mxCell>
        <mxCell id="master-c859" value="5. onEventWriteUpdateCountryStats → external_country_stats" style="rounded=1;arcSize=30;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#9E9E9E;fontColor=#263238;strokeColor=#1565C0;" vertex="1" parent="master-m854"><mxGeometry x="9" y="143" width="400" height="22" as="geometry"/></mxCell>
        <mxCell id="master-c860" value="6. client pager reads nearest-first, cache-first" style="rounded=1;arcSize=30;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#9E9E9E;fontColor=#263238;strokeColor=#1565C0;" vertex="1" parent="master-m854"><mxGeometry x="9" y="170" width="400" height="22" as="geometry"/></mxCell>
        <mxCell id="master-m861" value="④ DELIVER PUSH NOTIFICATION" style="swimlane;html=1;rounded=1;arcSize=4;startSize=24;fontSize=11;fontStyle=1;fillColor=#FFFFFF;strokeColor=#9E9E9E;fontColor=#263238;swimlaneFillColor=#FFFFFF;collapsible=1;startSize=26;" vertex="1" parent="master-g839"><mxGeometry x="1316" y="44" width="418" height="201" as="geometry"><mxRectangle x="1316" y="44" width="260" height="44" as="alternateBounds"/></mxGeometry></mxCell>
        <mxCell id="master-c862" value="1. domain trigger writes notifications/{uid}/items/{id}" style="rounded=1;arcSize=30;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#9E9E9E;fontColor=#263238;strokeColor=#E65100;" vertex="1" parent="master-m861"><mxGeometry x="9" y="35" width="400" height="22" as="geometry"/></mxCell>
        <mxCell id="master-c863" value="2. onNotificationCreatedPush (pushParity) picks it up" style="rounded=1;arcSize=30;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#9E9E9E;fontColor=#263238;strokeColor=#E65100;" vertex="1" parent="master-m861"><mxGeometry x="9" y="62" width="400" height="22" as="geometry"/></mxCell>
        <mxCell id="master-c864" value="3. shouldNotify() gate ⟵ notification_preferences (paid tier)" style="rounded=1;arcSize=30;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#9E9E9E;fontColor=#263238;strokeColor=#E65100;" vertex="1" parent="master-m861"><mxGeometry x="9" y="89" width="400" height="22" as="geometry"/></mxCell>
        <mxCell id="master-c865" value="4. sendPushNotification → FCM token multicast" style="rounded=1;arcSize=30;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#9E9E9E;fontColor=#263238;strokeColor=#E65100;" vertex="1" parent="master-m861"><mxGeometry x="9" y="116" width="400" height="22" as="geometry"/></mxCell>
        <mxCell id="master-c866" value="5. client: firebase_messaging + flutter_local_notifications" style="rounded=1;arcSize=30;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#9E9E9E;fontColor=#263238;strokeColor=#E65100;" vertex="1" parent="master-m861"><mxGeometry x="9" y="143" width="400" height="22" as="geometry"/></mxCell>
        <mxCell id="master-c867" value="6. trackNotificationOpened → analytics" style="rounded=1;arcSize=30;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#9E9E9E;fontColor=#263238;strokeColor=#E65100;" vertex="1" parent="master-m861"><mxGeometry x="9" y="170" width="400" height="22" as="geometry"/></mxCell>
        <mxCell id="master-c868" value="&lt;b&gt;ARCHITECTURAL CONSTRAINTS &amp;amp; KNOWN TRAPS (carry these into every change)&lt;/b&gt;&lt;br&gt;&lt;br&gt;• &lt;b&gt;Flavor first.&lt;/b&gt; &lt;b&gt;culture&lt;/b&gt; is the default on web/iOS/Android; the 9 dating switches are OFF. Anything dashed above must not mount, listen, or count usage in the default build (Apple 4.3(b)).&lt;br&gt;• &lt;b&gt;Coin model split.&lt;/b&gt; The client reads &lt;i&gt;camelCase&lt;/i&gt; &lt;b&gt;coinBalances&lt;/b&gt; only. The snake_case &lt;b&gt;coin_balances&lt;/b&gt; / &lt;b&gt;coin_transactions&lt;/b&gt; functions are phantom — do not wire new code to them.&lt;br&gt;• &lt;b&gt;Functions memory.&lt;/b&gt; The functions index needs ~200 MB RSS just to load, so a function at or below 256 MiB can be OOM-killed on cold start — and a killed trigger drops its event silently. Audited state: &lt;b&gt;17 declarations at 128 MiB and 99 at 256 MiB are still at risk&lt;/b&gt;, 63 are at 512 MiB (that is where the push functions were moved), and 53 of the 102 .ts files declare no memory at all and inherit the platform default. See the MEMORY POSTURE panel in band 5.&lt;br&gt;• &lt;b&gt;Deploy by name.&lt;/b&gt; Orphaned production functions abort a full &lt;b&gt;firebase deploy --only functions&lt;/b&gt;.&lt;br&gt;• &lt;b&gt;Rules do not cascade.&lt;/b&gt; A &lt;b&gt;match /users/{uid}&lt;/b&gt; rule does NOT cover &lt;b&gt;users/{uid}/sub/{doc}&lt;/b&gt; — subcollections need their own match blocks (this broke chat-media upload and coin-gift notifications).&lt;br&gt;• &lt;b&gt;Scale posture.&lt;/b&gt; Every read path must paginate, denormalise or shard — no unbounded collection scans. Fan-out on write (user_group_inbox, external_events_index) is the house pattern.&lt;br&gt;• &lt;b&gt;i18n.&lt;/b&gt; No hardcoded UI text: add the key to lib/l10n/app_en.arb → &lt;b&gt;flutter gen-l10n&lt;/b&gt; → &lt;b&gt;AppLocalizations.of(context)!.key&lt;/b&gt;." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=11;fontColor=#5D4037;spacing=8;" vertex="1" parent="1"><mxGeometry x="20" y="4230" width="4560" height="187" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
