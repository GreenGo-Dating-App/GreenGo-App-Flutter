        <mxCell id="master-m847" value="② SPEND / GRANT COINS" style="swimlane;html=1;rounded=1;arcSize=4;startSize=24;fontSize=11;fontStyle=1;fillColor=#FFFFFF;strokeColor=#9E9E9E;fontColor=#263238;swimlaneFillColor=#FFFFFF;collapsible=1;startSize=26;" vertex="1" parent="master-g839"><mxGeometry x="448" y="44" width="418" height="201" as="geometry"><mxRectangle x="448" y="44" width="260" height="44" as="alternateBounds"/></mxGeometry></mxCell>
        <mxCell id="master-c848" value="1. ShopScreen → verifyGooglePlayCoinPurchase (callable)" style="rounded=1;arcSize=30;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#9E9E9E;fontColor=#263238;strokeColor=#AD1457;" vertex="1" parent="master-m847"><mxGeometry x="9" y="35" width="400" height="22" as="geometry"/></mxCell>
