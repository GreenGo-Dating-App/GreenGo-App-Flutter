        <mxCell id="p09-e118" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;jettySize=auto;orthogonalLoop=1;strokeColor=#37474F;strokeWidth=2;endArrow=blockThin;exitX=1;exitY=0.08;exitDx=0;exitDy=0;entryX=0;entryY=0.08;entryDx=0;entryDy=0;" edge="1" parent="1" source="p09-L56" target="p09-L82"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p09-e119" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;jettySize=auto;orthogonalLoop=1;strokeColor=#37474F;strokeWidth=2;endArrow=blockThin;exitX=1;exitY=0.08;exitDx=0;exitDy=0;entryX=0;entryY=0.08;entryDx=0;entryDy=0;" edge="1" parent="1" source="p09-L82" target="p09-L109"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p09-c120" value="&lt;b&gt;Learning-by-doing.&lt;/b&gt; Gamification is not a bolt-on: &lt;b&gt;onMessageCreatedVocabulary&lt;/b&gt; mines real chat messages for vocabulary, which feeds &lt;b&gt;user_vocabulary&lt;/b&gt; and the word games. That loop is the product thesis — XP comes from actually communicating across a language barrier.&lt;br&gt;&lt;b&gt;Cost control.&lt;/b&gt; Chirp 3 HD TTS is coin-gated AND cached in &lt;b&gt;pronunciation_cache&lt;/b&gt;; the per-tier &lt;b&gt;tierPerkTtsCost&lt;/b&gt; decides the coin price. Never call TTS without checking the cache first.&lt;br&gt;&lt;b&gt;Leaderboards.&lt;/b&gt; &lt;b&gt;updateLeaderboardRankings&lt;/b&gt; is scheduled — never compute rankings by scanning users on read." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=11;fontColor=#5D4037;spacing=8;" vertex="1" parent="1"><mxGeometry x="20" y="947" width="1906" height="85" as="geometry"/></mxCell>
        <mxCell id="p09-c121" value="Gamification &amp; Language Learning  —  Low-Level Design" style="text;html=1;fontSize=22;fontStyle=1;fontColor=#1B5E20;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="20" y="16" width="1712" height="34" as="geometry"/></mxCell>
