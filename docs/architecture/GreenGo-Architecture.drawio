        <mxCell id="p07-e78" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;jettySize=auto;orthogonalLoop=1;strokeColor=#37474F;strokeWidth=2;endArrow=blockThin;exitX=1;exitY=0.08;exitDx=0;exitDy=0;entryX=0;entryY=0.08;entryDx=0;entryDy=0;" edge="1" parent="1" source="p07-L1" target="p07-L12"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p07-e79" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;jettySize=auto;orthogonalLoop=1;strokeColor=#37474F;strokeWidth=2;endArrow=blockThin;exitX=1;exitY=0.08;exitDx=0;exitDy=0;entryX=0;entryY=0.08;entryDx=0;entryDy=0;" edge="1" parent="1" source="p07-L12" target="p07-L23"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p07-e80" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;jettySize=auto;orthogonalLoop=1;strokeColor=#37474F;strokeWidth=2;endArrow=blockThin;exitX=1;exitY=0.08;exitDx=0;exitDy=0;entryX=0;entryY=0.08;entryDx=0;entryDy=0;" edge="1" parent="1" source="p07-L23" target="p07-L31"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p07-e81" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;jettySize=auto;orthogonalLoop=1;strokeColor=#37474F;strokeWidth=2;endArrow=blockThin;exitX=1;exitY=0.08;exitDx=0;exitDy=0;entryX=0;entryY=0.08;entryDx=0;entryDy=0;" edge="1" parent="1" source="p07-L31" target="p07-L58"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p07-c82" value="&lt;b&gt;Trace ④.&lt;/b&gt; Any domain trigger writes &lt;b&gt;notifications/{uid}/items/{id}&lt;/b&gt;; &lt;b&gt;onNotificationCreatedPush&lt;/b&gt; is the single parity point that converts an inbox row into a push. The server-side &lt;b&gt;shouldNotify&lt;/b&gt; gate reads &lt;b&gt;notification_preferences&lt;/b&gt; — per-category preferences are a paid-tier feature, so free users take the default policy.&lt;br&gt;&lt;b&gt;⚠ Memory trap.&lt;/b&gt; The functions index needs ~200 MB RSS just to load, so a function at or below 256 MiB can be OOM-killed on cold start and &lt;i&gt;its trigger event is dropped silently&lt;/i&gt; — this is what killed Android push once. Audited on 2026-07-21 across functions/src: 63 declarations sit at 512 MiB (the push path), but &lt;b&gt;99 are still at 256 MiB and 17 at 128 MiB&lt;/b&gt; (backup/, messaging/, notification/, notifications/brevoEmailService, safety/), and 53 of the 102 .ts files declare no memory at all. brevoEmailService carries 128 MiB declarations while also owning 13 email triggers — treat it as the next one to raise.&lt;br&gt;&lt;b&gt;Deploy.&lt;/b&gt; Always deploy functions BY NAME — orphaned prod functions abort a full deploy." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=11;fontColor=#5D4037;spacing=8;" vertex="1" parent="1"><mxGeometry x="20" y="1000" width="1604" height="136" as="geometry"/></mxCell>
        <mxCell id="p07-c83" value="Notifications &amp; Email  —  Low-Level Design" style="text;html=1;fontSize=22;fontStyle=1;fontColor=#1B5E20;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="20" y="16" width="1410" height="34" as="geometry"/></mxCell>
        <mxCell id="p07-c84" value="notifications (24 files · 2 BLoC · 6 usecases) · FCM push · per-category preferences 🔒 · city alerts · Brevo email · in-app inbox" style="text;html=1;fontSize=12;fontColor=#546E7A;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="20" y="54" width="1650" height="36" as="geometry"/></mxCell>
        <UserObject label="◀ back to MASTER" link="data:page/id,master" id="p07-c85"><mxCell style="rounded=1;arcSize=40;whiteSpace=wrap;html=1;fontSize=11;fontStyle=1;fillColor=#263238;strokeColor=#263238;fontColor=#FFFFFF;" vertex="1" parent="1"><mxGeometry x="1470" y="18" width="200" height="30" as="geometry"/></mxCell></UserObject>
      </root>
    </mxGraphModel>
  </diagram>
