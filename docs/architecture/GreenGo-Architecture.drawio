        <mxCell id="p11-e90" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;jettySize=auto;orthogonalLoop=1;strokeColor=#37474F;strokeWidth=2;endArrow=blockThin;exitX=1;exitY=0.08;exitDx=0;exitDy=0;entryX=0;entryY=0.08;entryDx=0;entryDy=0;" edge="1" parent="1" source="p11-L53" target="p11-L66"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p11-e91" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;jettySize=auto;orthogonalLoop=1;strokeColor=#37474F;strokeWidth=2;endArrow=blockThin;exitX=1;exitY=0.08;exitDx=0;exitDy=0;entryX=0;entryY=0.08;entryDx=0;entryDy=0;" edge="1" parent="1" source="p11-L66" target="p11-L79"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p11-c92" value="&lt;b&gt;Fresh-clone build.&lt;/b&gt; Three gitignored configs must be restored before anything builds: &lt;b&gt;firebase_options.dart&lt;/b&gt;, &lt;b&gt;google-services.json&lt;/b&gt;, and the release keystore. Keys live in the credentials file, never in git.&lt;br&gt;&lt;b&gt;Runnable is the bar.&lt;/b&gt; A change is not done when it compiles — the app must boot and smoke-test. On Android always &lt;b&gt;adb uninstall&lt;/b&gt; before installing, and disable Impeller on emulators (it renders black); &lt;b&gt;adb screencap&lt;/b&gt; cannot capture the Flutter surface.&lt;br&gt;&lt;b&gt;Scale posture.&lt;/b&gt; Everything here is designed to reach millions of users: pagination, denormalisation, batched fan-out and per-user indexed reads are mandatory, not optional." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=11;fontColor=#5D4037;spacing=8;" vertex="1" parent="1"><mxGeometry x="20" y="732" width="1961" height="85" as="geometry"/></mxCell>
        <mxCell id="p11-c93" value="Platform, Data Model &amp; DevOps  —  Low-Level Design" style="text;html=1;fontSize=22;fontStyle=1;fontColor=#1B5E20;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="20" y="16" width="1767" height="34" as="geometry"/></mxCell>
        <mxCell id="p11-c94" value="build flavors · CI/CD · security rules matrix · indexes · Terraform · Docker · testing · GCP enterprise migration path" style="text;html=1;fontSize=12;fontColor=#546E7A;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="20" y="54" width="2007" height="36" as="geometry"/></mxCell>
