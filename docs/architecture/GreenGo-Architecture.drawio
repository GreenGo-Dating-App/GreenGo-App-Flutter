        <mxCell id="p01-e121" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;jettySize=auto;orthogonalLoop=1;strokeColor=#37474F;strokeWidth=2;endArrow=blockThin;exitX=1;exitY=0.08;exitDx=0;exitDy=0;entryX=0;entryY=0.08;entryDx=0;entryDy=0;" edge="1" parent="1" source="p01-L77" target="p01-L97"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p01-c122" value="&lt;b&gt;Notes.&lt;/b&gt; AuthWrapper in main.dart decides Splash → Login → Onboarding → MainNavigation. &lt;b&gt;nicknames/&lt;/b&gt; is a uniqueness index written transactionally with the profile. Explore search is case-insensitive and prefix-matches on BOTH name and nickname (hence the &lt;b&gt;country_lower&lt;/b&gt; / lowercase backfill scripts in functions/). Deleting an account must fan out: Auth user, profiles, users, media in Storage, and every denormalised copy (attendees, members, user_group_inbox) — &lt;b&gt;onProfileDeleted&lt;/b&gt; owns this.&lt;br&gt;&lt;b&gt;Trap.&lt;/b&gt; firestore.rules do not cascade into &lt;b&gt;users/{uid}/**&lt;/b&gt; subcollections; each needs its own match block or writes silently fail." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=11;fontColor=#5D4037;spacing=8;" vertex="1" parent="1"><mxGeometry x="20" y="948" width="1886" height="85" as="geometry"/></mxCell>
        <mxCell id="p01-c123" value="Identity, Onboarding &amp; Profile  —  Low-Level Design" style="text;html=1;fontSize=22;fontStyle=1;fontColor=#1B5E20;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="20" y="16" width="1692" height="34" as="geometry"/></mxCell>
        <mxCell id="p01-c124" value="authentication (21 files) · profile (57 files, 28 screens) · membership · passport · legal · accessibility · localization · app_tour / app_guide" style="text;html=1;fontSize=12;fontColor=#546E7A;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="20" y="54" width="1932" height="36" as="geometry"/></mxCell>
