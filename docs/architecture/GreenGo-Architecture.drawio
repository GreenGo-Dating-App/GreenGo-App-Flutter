        <mxCell id="p03-e124" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;jettySize=auto;orthogonalLoop=1;strokeColor=#37474F;strokeWidth=2;endArrow=blockThin;exitX=1;exitY=0.08;exitDx=0;exitDy=0;entryX=0;entryY=0.08;entryDx=0;entryDy=0;" edge="1" parent="1" source="p03-L71" target="p03-L91"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p03-c125" value="&lt;b&gt;Trace ①.&lt;/b&gt; GroupChatScreen → SendGroupMessage → groups/{gid}/messages → &lt;b&gt;onGroupMessageCreated&lt;/b&gt; fans out one small doc per member into &lt;b&gt;user_group_inbox/{uid}&lt;/b&gt; → &lt;b&gt;onNewMessagePush&lt;/b&gt; multicasts FCM. Members never query the group collection to build their list — that is the fan-out-on-write pattern that keeps group chat O(1) per reader.&lt;br&gt;&lt;b&gt;Rules.&lt;/b&gt; Group chat is a SEPARATE collection from 1:1 &lt;b&gt;conversations&lt;/b&gt; — never merge them. Chat-media upload paths in storage.rules must stay explicitly allowed (a lockdown broke this once).&lt;br&gt;&lt;b&gt;Cache.&lt;/b&gt; Hive backs the message list for instant cold-start; pagination is required on every message query." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=11;fontColor=#5D4037;spacing=8;" vertex="1" parent="1"><mxGeometry x="20" y="1083" width="1916" height="102" as="geometry"/></mxCell>
        <mxCell id="p03-c126" value="Messaging &amp; Chat  —  Low-Level Design" style="text;html=1;fontSize=22;fontStyle=1;fontColor=#1B5E20;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="20" y="16" width="1722" height="34" as="geometry"/></mxCell>
        <mxCell id="p03-c127" value="chat (74 files · 9 screens · 4 BLoC · 28 usecases) · group chat · conversation_expiry · icebreakers · stories · translation · presence" style="text;html=1;fontSize=12;fontColor=#546E7A;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="20" y="54" width="1962" height="36" as="geometry"/></mxCell>
        <UserObject label="◀ back to MASTER" link="data:page/id,master" id="p03-c128"><mxCell style="rounded=1;arcSize=40;whiteSpace=wrap;html=1;fontSize=11;fontStyle=1;fillColor=#263238;strokeColor=#263238;fontColor=#FFFFFF;" vertex="1" parent="1"><mxGeometry x="1782" y="18" width="200" height="30" as="geometry"/></mxCell></UserObject>
      </root>
    </mxGraphModel>
