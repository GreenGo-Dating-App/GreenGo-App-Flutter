<mxfile host="app.diagrams.net" modified="2026-03-10">
  <diagram name="Firestore Data Model" id="datamodel">
    <mxGraphModel dx="1800" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="GreenGo Firestore Data Model (ERD)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=22;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="800" y="20" width="600" height="40" as="geometry" />
        </mxCell>
        <!-- Users/Profiles -->
        <mxCell id="profiles" value="profiles {userId}&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;displayName: String&#xa;nickname: String?&#xa;dateOfBirth: Timestamp&#xa;gender: String&#xa;accountStatus: String&#xa;photoUrls: String[]&#xa;bio: String&#xa;interests: String[]&#xa;location: GeoPoint&#xa;languages: String[]&#xa;verificationStatus: String&#xa;membershipTier: String&#xa;isAdmin: Boolean&#xa;isOnline: Boolean&#xa;lastSeen: Timestamp&#xa;createdAt: Timestamp" style="shape=table;startSize=30;container=0;collapsible=0;childLayout=tableLayout;fillColor=#60a917;fontColor=#ffffff;strokeColor=#2D7600;fontSize=11;align=left;whiteSpace=wrap;html=1;rounded=1" vertex="1" parent="1">
          <mxGeometry x="100" y="80" width="240" height="340" as="geometry" />
        </mxCell>
        <!-- Conversations -->
