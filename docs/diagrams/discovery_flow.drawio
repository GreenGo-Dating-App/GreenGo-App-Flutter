          <mxGeometry x="330" y="510" width="240" height="120" as="geometry" />
        </mxCell>
        <!-- Sort & Return -->
        <mxCell id="sort" value="Sort by Score DESC&#xa;Limit to 20 candidates&#xa;Cache results (session)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d79b00;fontColor=#ffffff;strokeColor=#B57900;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="340" y="670" width="220" height="60" as="geometry" />
        </mxCell>
        <!-- User Swipe -->
