<mxfile host="app.diagrams.net" modified="2026-03-10">
  <diagram name="Discovery and Matching Flow" id="discovery">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Discovery &amp; Matching Flow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="400" height="40" as="geometry" />
        </mxCell>
        <!-- Start -->
        <mxCell id="start" value="User Opens&#xa;Discovery Tab" style="ellipse;whiteSpace=wrap;html=1;fillColor=#60a917;fontColor=#ffffff;strokeColor=#2D7600;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="140" height="70" as="geometry" />
        </mxCell>
        <!-- Check Cache -->
        <mxCell id="cache_check" value="Session&#xa;Cache Valid?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f0a30a;strokeColor=#BD7000;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="70" y="190" width="120" height="100" as="geometry" />
        </mxCell>
        <!-- Parallel Fetch -->
        <mxCell id="parallel" value="Parallel Firestore Queries&#xa;(Future.wait)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1ba1e2;fontColor=#ffffff;strokeColor=#006EAF;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="300" y="100" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="q1" value="Get Swipe History&#xa;(90-day window)&#xa;userId + timestamp DESC&#xa;limit: 2000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="250" y="180" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="q2" value="Get Matched IDs&#xa;userId1/userId2&#xa;isActive = true&#xa;limit: 1000 each" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="430" y="180" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="q3" value="Get Blocked IDs&#xa;blockerId = userId&#xa;Both directions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="610" y="180" width="140" height="80" as="geometry" />
        </mxCell>
        <!-- Filter -->
        <mxCell id="filter" value="Build Exclusion Set&#xa;(swiped + matched + blocked)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="350" y="300" width="220" height="50" as="geometry" />
        </mxCell>
        <!-- Get Profiles -->
        <mxCell id="get_profiles" value="Query Candidate Profiles&#xa;- Match preferences (age, gender, distance)&#xa;- Exclude already-swiped&#xa;- accountStatus = active&#xa;- isComplete = true" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#60a917;fontColor=#ffffff;strokeColor=#2D7600;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="310" y="390" width="280" height="80" as="geometry" />
        </mxCell>
        <!-- Admin Candidate -->
        <mxCell id="admin_cand" value="Get Admin Candidate&#xa;(1-hour cache TTL)&#xa;Always shown as&#xa;recommended" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="650" y="390" width="160" height="80" as="geometry" />
        </mxCell>
