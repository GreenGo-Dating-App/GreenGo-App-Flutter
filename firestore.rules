rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================================
    // HELPER FUNCTIONS
    // ============================================================================

    // Check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if user owns the resource
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Check if user is admin (legacy — checks users collection)
    function isAdmin() {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Check if user is admin panel user (checks admin_users collection)
    function isAdminPanelUser() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    // Check if the acting user is a profile-level admin (profiles/{uid}.isAdmin).
    // Used by the in-app admin tools (e.g. business-verification review) which
    // gate on the Profile.isAdmin flag rather than the admin panel collections.
    function isProfileAdmin() {
      return isSignedIn() &&
             get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.isAdmin == true;
    }

    // ============================================================================
    // USERS COLLECTION
    // ============================================================================
    match /users/{userId} {
      allow read: if isSignedIn();
      // Owner may create their own doc but NEVER seed a privilege field.
      allow create: if isOwner(userId)
        && request.resource.data.get('role', '') != 'admin'
        && request.resource.data.get('isAdmin', false) == false;
      // Owner may update their own doc but NEVER change role / isAdmin — those
      // are admin / Cloud-Function only (closes the self-promote-to-admin hole).
      allow update: if (isOwner(userId)
              && request.resource.data.get('role', resource.data.get('role', ''))
                 == resource.data.get('role', '')
              && request.resource.data.get('isAdmin', false)
                 == resource.data.get('isAdmin', false))
        || isAdminPanelUser();
      allow delete: if isOwner(userId);
    }

    // ============================================================================
    // USER INTERACTIONS COLLECTION (search + click tracking → recommendations)
    // ============================================================================
    // Write-only from clients: a user may only append their own interaction
    // events. Reads are blocked entirely — only backend/admin (Cloud Functions
    // with the Admin SDK, which bypasses rules) consumes this data.
    match /user_interactions/{userId}/{document=**} {
      allow create: if isOwner(userId);
      allow read: if false;
    }

    // ============================================================================
    // PROFILES COLLECTION
    // ============================================================================
    match /profiles/{profileId} {
      // Anyone signed in can read profiles (for discovery/matching)
      allow read: if isSignedIn();
      // Users can create/update/delete their own profile; admins can update (verification, moderation)
      allow create: if isOwner(profileId);
      // Owner, admin-panel and profile-admins (business-verification approval →
      // sets businessVerified) may update. Additionally ANY signed-in user may
      // change ONLY the denormalized `followerCount` (business follow/unfollow
      // runs as the follower, not the business owner).
      // Owner may update their own profile EXCEPT the moderation flag
      // `isBanned` (only admins/Cloud Functions may set/clear it — a banned
      // user must never be able to self-unban). Any signed-in user may also
      // change ONLY the denormalized counters (followerCount / rating aggregate).
      allow update: if (isOwner(profileId)
              && request.resource.data.get('isBanned', false)
                 == resource.data.get('isBanned', false)
              // NEVER let the owner set their own admin / verification flags.
              && request.resource.data.get('isAdmin', false)
                 == resource.data.get('isAdmin', false)
              && request.resource.data.get('isBusinessVerified', false)
                 == resource.data.get('isBusinessVerified', false)
              && request.resource.data.get('businessVerified', false)
                 == resource.data.get('businessVerified', false))
        || isAdminPanelUser() || isProfileAdmin()
        || (isSignedIn()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['followerCount', 'ratingSum', 'ratingCount']));
      allow delete: if isOwner(profileId);
    }

    // ============================================================================
    // MATCHES COLLECTION
    // ============================================================================
    match /matches/{matchId} {
      // Authenticated users can read/write matches
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // ============================================================================
    // LIKES COLLECTION
    // ============================================================================
    match /likes/{likeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isSignedIn();
    }

    // ============================================================================
    // CONVERSATIONS COLLECTION
    // ============================================================================
    match /conversations/{conversationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();

      // MESSAGES SUBCOLLECTION
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isSignedIn();
      }
    }

    // ============================================================================
    // SUBSCRIPTIONS COLLECTION
    // ============================================================================
    match /subscriptions/{subscriptionId} {
      allow read: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ============================================================================
    // TRANSACTIONS COLLECTION (GreenGoCoins)
    // ============================================================================
    match /transactions/{transactionId} {
      allow read: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ============================================================================
    // REPORTS COLLECTION
    // ============================================================================
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ============================================================================
    // BLOCKED USERS COLLECTION
    // ============================================================================
    match /blockedUsers/{blockId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isSignedIn();
    }

    match /blocked_users/{blockId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isSignedIn();
    }

    // ============================================================================
    // NOTIFICATIONS COLLECTION
    // ============================================================================
    match /notifications/{notificationId} {
      // A user may only read/modify/delete THEIR OWN notifications (they carry
      // actor photos + message previews). Create stays open because the client
      // legitimately writes notifications FOR other users (like/match) — those
      // are cross-user by design; server writes use the Admin SDK anyway.
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ============================================================================
    // COIN BALANCES COLLECTION
    // ============================================================================
    match /coin_balances/{userId} {
      // Legacy/unused collection — the app uses `coinBalances` (camelCase).
      // Backend functions use the Admin SDK (bypasses rules); deny all client
      // access to reduce attack surface.
      allow read, write: if false;
    }

    // ============================================================================
    // COIN TRANSACTIONS COLLECTION
    // ============================================================================
    match /coin_transactions/{transactionId} {
      // Legacy/unused collection — the app uses `coinTransactions` (camelCase).
      allow read, write: if false;
    }

    // ============================================================================
    // USER LEVELS COLLECTION (Gamification/Leaderboard)
    // ============================================================================
    match /user_levels/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // ============================================================================
    // GAMIFICATION COLLECTIONS
    // ============================================================================
    match /achievement_progress/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /challenge_progress/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /xp_transactions/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    // ============================================================================
    // STREAKS & MISSIONS (daily engagement streak + coin-rewarding missions)
    // ============================================================================
    // streaks/{userId} = { current, longest, lastActiveDay, awardedMilestones,
    //                      updatedAt } — owner-only single doc per user.
    match /streaks/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    // mission_progress/{userId} = { claimed: [missionId...], updatedAt }
    // Only the claimed-rewards set is stored; live progress is derived client-side.
    match /mission_progress/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    match /seasonal_events/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ============================================================================
    // ALBUM ACCESS COLLECTION
    // ============================================================================
    match /album_access/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // ============================================================================
    // MATCHING / ML COLLECTIONS (used by discovery algorithm)
    // ============================================================================
    match /user_vectors/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    match /match_preferences/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    match /user_interactions/{docId} {
      allow read: if isSignedIn();
      // A user may only record their OWN interaction events (userId must match).
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    match /interaction_matrix/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    // ============================================================================
    // SWIPES / DISCOVERY COLLECTION
    // ============================================================================
    match /swipes/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /discovery_queue/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // ============================================================================
    // CONVERSATION EXPIRY COLLECTION
    // ============================================================================
    match /conversation_expiry/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // ============================================================================
    // PHOTO LIKES COLLECTION
    // ============================================================================
    match /photo_likes/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isSignedIn();
    }

    // ============================================================================
    // ANALYTICS COLLECTION (Admin only)
    // ============================================================================
    match /analytics/{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ============================================================================
    // USAGE LIMITS COLLECTION (hourly likes/nopes/superLikes + daily/monthly)
    // UsageLimitService writes to usageLimits/{userId}/hours/{YYYY-MM-DD-HH}
    //                                  and usageLimits/{userId}/days/{YYYY-MM-DD}
    // ============================================================================
    match /usageLimits/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if false;

      match /hours/{hourId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId);
        allow delete: if false;
      }

      match /days/{dayId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId);
        allow delete: if false;
      }
    }

    // ============================================================================
    // DAILY USAGE COLLECTION (legacy — kept for backwards compatibility)
    // ============================================================================
    match /dailyUsage/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if false;

      match /days/{dayId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId);
        allow delete: if false;
      }
    }

    // ============================================================================
    // COIN BALANCES COLLECTION (alternate path)
    // ============================================================================
    match /coinBalances/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Owner may update their own balance (spend / earn / welcome coins).
      // A non-owner (e.g. gifting or refunding coins to another user) may ONLY
      // INCREASE totalCoins — never decrement or zero out someone else's
      // balance. Full balance integrity needs server-side mutations; this
      // closes the worst case (draining/zeroing another user).
      allow update: if isOwner(userId)
        || (isSignedIn()
            && request.resource.data.totalCoins > resource.data.totalCoins);
      allow delete: if false;
    }

    // ============================================================================
    // COIN GIFTS COLLECTION
    // ============================================================================
    match /coinGifts/{giftId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;
    }

    // ============================================================================
    // REFERRAL LOOP (invite a friend — both earn coins)
    // ============================================================================
    // referral_codes/{CODE} = { ownerId, createdAt }
    // Any signed-in user may read (to resolve a code when redeeming). The owner
    // may create their own code (ownerId must equal their uid). Codes are
    // immutable once created.
    match /referral_codes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if false;
    }

    // referrals/{userId} = { code, invitedCount, coinsEarned, redeemedCode? }
    // Owner may read/write their own referral doc. A non-owner (the referrer)
    // may ONLY increment counters when a friend redeems their code — never
    // decrement — mirroring the coinBalances integrity guard.
    match /referrals/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId)
        || (isSignedIn()
            && request.resource.data.invitedCount > resource.data.invitedCount);
      allow delete: if false;
    }

    // ============================================================================
    // COIN TRANSACTIONS COLLECTION (alternate path)
    // ============================================================================
    match /coinTransactions/{transactionId} {
      allow read: if isSignedIn();
      // A user may only create ledger entries they're a party to — their own
      // (userId) or as the counterparty of a gift/refund (relatedUserId).
      // Blocks forging arbitrary third-party ledger entries.
      allow create: if isSignedIn()
        && (request.resource.data.userId == request.auth.uid
            || request.resource.data.get('relatedUserId', '') == request.auth.uid);
      allow update: if false;
      allow delete: if false;
    }

    // ============================================================================
    // VIDEO COINS + INVOICES (were unruled → catch-all denied the user's own
    // writes, breaking the client video-coin ledger + invoice generation).
    // ============================================================================
    match /videoCoinBalances/{userId} {
      allow read, create, update: if isOwner(userId);
      allow delete: if false;
    }
    match /videoCoinTransactions/{transactionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
    match /invoices/{invoiceId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ============================================================================
    // COIN PROMOTIONS COLLECTION
    // ============================================================================
    match /coinPromotions/{promotionId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ============================================================================
    // CLAIMED REWARDS COLLECTION
    // ============================================================================
    match /claimedRewards/{rewardId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    // ============================================================================
    // COIN ORDERS COLLECTION
    // ============================================================================
    match /coinOrders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;
    }

    // ============================================================================
    // MEMBERSHIPS COLLECTION
    // ============================================================================
    match /memberships/{membershipId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // ============================================================================
    // LEGAL DOCUMENTS COLLECTION
    // ============================================================================
    match /legalDocuments/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ============================================================================
    // TIER CONFIGS COLLECTION
    // ============================================================================
    match /tierConfigs/{configId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ============================================================================
    // MESSAGE REPORTS COLLECTION
    // ============================================================================
    match /message_reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ============================================================================
    // USER REPORTS COLLECTION
    // ============================================================================
    match /user_reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ============================================================================
    // NICKNAMES COLLECTION (public read for nickname login before auth)
    // ============================================================================
    match /nicknames/{nickname} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ============================================================================
    // FEATURE FLAGS & APP CONFIG (read without auth for startup)
    // ============================================================================
    match /featureFlags/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /appConfig/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /app_config/{docId} {
      allow read: if true;
      allow write: if isAdminPanelUser();
    }

    // ============================================================================
    // FUNCTION MONITORS (Cloud Function invocation stats)
    // ============================================================================
    // Written by Cloud Functions via the Admin SDK (bypasses rules). The admin
    // panel reads stats and may reset/clear a function's counters.
    match /function_monitors/{functionName} {
      allow read: if isAdminPanelUser();
      allow write: if isAdminPanelUser();
    }

    // ============================================================================
    // ADMIN USERS COLLECTION (admin panel authentication)
    // ============================================================================
    match /admin_users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdminPanelUser();
    }

    // ============================================================================
    // ADMIN ACTIONS & AUDIT COLLECTIONS (admin panel logging)
    // ============================================================================
    match /admin_actions/{actionId} {
      allow read: if isAdminPanelUser() || isProfileAdmin();
      allow create: if isAdminPanelUser() || isProfileAdmin();
      allow update, delete: if false;
    }

    match /admin_audit_index/{docId} {
      allow read: if isAdminPanelUser();
      allow create: if isAdminPanelUser();
      allow update, delete: if false;
    }

    // Monthly audit log collections (admin_audit_logs_YYYY_MM)
    // Firestore rules don't support regex on collection names, so we use
    // the catch-all below. These collections are written by admin panel only.

    // ============================================================================
    // NOTIFICATION PREFERENCES COLLECTION
    // ============================================================================
    match /notification_preferences/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    // ============================================================================
    // VIRTUAL GIFTS COLLECTION
    // ============================================================================
    match /virtualGifts/{giftId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;
    }

    // ============================================================================
    // BLIND MATCHES COLLECTION
    // ============================================================================
    match /blindMatches/{matchId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // ============================================================================
    // SECOND CHANCE POOL COLLECTION
    // ============================================================================
    match /secondChancePool/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // ============================================================================
    // MEMBERSHIP PURCHASES — tracks which app user owns each IAP purchase
    // ============================================================================
    match /membership_purchases/{purchaseId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if false; // Immutable once created
    }

    // ============================================================================
    // SUPPORT CHATS COLLECTION
    // ============================================================================
    match /support_chats/{chatId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;
    }

    // ============================================================================
    // SUPPORT MESSAGES COLLECTION
    // ============================================================================
    match /support_messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;
    }

    // ============================================================================
    // LANGUAGE GAMES COLLECTIONS
    // ============================================================================
    match /game_rooms/{roomId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();

      // Rounds subcollection (game rounds data)
      match /rounds/{roundId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn();
        allow delete: if false;
      }

      // Chat subcollection (in-game chat messages)
      match /chat/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if false;
      }
    }

    // GAME INVITES COLLECTION
    match /game_invites/{inviteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /game_matchmaking/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /game_stats/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // ============================================================================
    // CONSTELLATION COLLECTION (Language Learning — galaxy map nodes)
    // ============================================================================
    match /constellation/{nodeId} {
      allow read: if isSignedIn();
      allow write: if isAdminPanelUser();
    }

    // ============================================================================
    // LESSONS COLLECTION (Language Learning — lesson questions)
    // ============================================================================
    match /lessons/{lessonId} {
      allow read: if isSignedIn();
      allow write: if isAdminPanelUser();
    }

    // ============================================================================
    // GAME WORDS COLLECTION (language game vocabulary — read-only for players)
    // ============================================================================
    match /game_words/{wordId} {
      allow read: if isSignedIn();
      allow write: if isAdminPanelUser();
    }

    // ============================================================================
    // GAME GRAMMAR QUESTIONS (grammar duel questions — read-only for players)
    // ============================================================================
    match /game_grammar_questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdminPanelUser();
    }

    // ============================================================================
    // GAME TRANSLATION RACE (pre-built translation questions — read-only)
    // ============================================================================
    match /game_translation_race/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdminPanelUser();
    }

    // ============================================================================
    // GAME REPORTED WORDS (players can report inappropriate words)
    // ============================================================================
    match /game_reported_words/{reportId} {
      allow read: if isAdminPanelUser();
      allow create: if isSignedIn();
      allow update, delete: if isAdminPanelUser();
    }

    // ============================================================================
    // PRONUNCIATION CACHE (TTS audio URL cache — shared across all users)
    // ============================================================================
    match /pronunciation_cache/{cacheId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdminPanelUser();
    }

    // Note: 'lessons' and 'constellation' collections already have rules above

    // ============================================================================
    // USER VOCABULARY (tracked words per user, written client-side on message send)
    // ============================================================================
    match /user_vocabulary/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId);

      match /words/{wordId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId);
      }
    }

    // ============================================================================
    // VOCABULARY WORDS (word frequency corpus — read-only for clients)
    // ============================================================================
    match /vocabulary_words/{langId} {
      allow read: if isSignedIn();

      match /words/{wordId} {
        allow read: if isSignedIn();
      }
    }

    // ============================================================================
    // COUPONS — Cloud Functions only.
    // Clients (including admins) must use redeemCoupon / upsertCoupon callables.
    // Direct reads are denied so coupon codes cannot be leaked or enumerated.
    // ============================================================================
    match /coupons/{couponId} {
      allow read, write: if false;
      match /redemptions/{userId} {
        allow read, write: if false;
      }
    }

    // ============================================================================
    // GROUP CHAT ("Culture Circles") — isolated `groups` collection
    // Cross-user writes are performed by Cloud Functions (Admin SDK, which
    // bypasses these rules). Clients only write the group doc + their own data.
    // ============================================================================
    match /groups/{groupId} {
      function isGroupMember() {
        return isSignedIn() && request.auth.uid in resource.data.participants;
      }
      function isGroupAdminRole() {
        return isSignedIn() && resource.data.roles[request.auth.uid] == 'admin';
      }

      allow read: if isGroupMember();
      // Creator must be in participants and be their own admin.
      allow create: if isSignedIn()
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.roles[request.auth.uid] == 'admin';
      // Members may update the group doc (membership/info/role ops); the
      // server-side functions perform the cross-user side effects.
      allow update: if isGroupMember();
      allow delete: if isGroupAdminRole();

      match /messages/{messageId} {
        function members() {
          return get(/databases/$(database)/documents/groups/$(groupId)).data.participants;
        }
        allow read: if isSignedIn() && request.auth.uid in members();
        allow create: if isSignedIn()
                      && request.auth.uid in members()
                      && request.resource.data.senderId == request.auth.uid;
        // Reactions / read-state by any member; hard delete only by the sender.
        allow update: if isSignedIn() && request.auth.uid in members();
        allow delete: if isSignedIn()
                      && resource.data.senderId == request.auth.uid;
      }

      match /members/{memberId} {
        function members() {
          return get(/databases/$(database)/documents/groups/$(groupId)).data.participants;
        }
        allow read: if isSignedIn() && request.auth.uid in members();
        // A user may write only their OWN member doc (e.g. lastReadAt). All
        // other member docs are written by Cloud Functions (Admin SDK).
        allow write: if isOwner(memberId);
      }
    }

    // Per-user group inbox index — strictly private to its owner. Summaries are
    // written by Cloud Functions; the owner may reset their own unread counter.
    match /user_group_inbox/{userId} {
      allow read, write: if isOwner(userId);
      match /threads/{groupId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Per-user PRIVATE group tags — each user's own labels for their groups.
    // Strictly private to the owner; never read/written by anyone else or by CFs.
    // Shape: user_group_tags/{userId} = { groupTags: { groupId: [tag, ...] } }
    match /user_group_tags/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Per-user PRIVATE people tags — each user's own labels for other users.
    // Strictly private to the owner; never read/written by anyone else or by CFs.
    // Shape: user_people_tags/{userId} = { peopleTags: { targetUserId: [tag, ...] } }
    match /user_people_tags/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Per-user PRIVATE favorite communities — each user's own starred list.
    // Strictly private to the owner; never read/written by anyone else or by CFs.
    // Shape: user_favorite_communities/{userId} = { communityIds: [id, ...] }
    match /user_favorite_communities/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Per-user PRIVATE saved discovery searches — each user's named snapshots of
    // the Network Discovery filter state (preferences + tags + query + alerts).
    // Strictly private to the owner. A saved-search-alerts Cloud Function (if
    // added later) uses the Admin SDK, which bypasses these client rules.
    // Shape: saved_searches/{userId}/searches/{id} = { name, preferences,
    //   tags, query, alertsEnabled, createdAt }
    match /saved_searches/{userId}/searches/{searchId} {
      allow read, write: if isOwner(userId);
    }

    // Cultural Passport — per-user collection of country/language/event stamps.
    // Shape: user_passports/{userId} = { countryStamps: [ISO...],
    //   languageStamps: [lang...], eventStamps: [category...], updatedAt }
    match /user_passports/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // ============================================================================
    // EXTERNAL EVENTS (Tiqets/Viator experiences) — read-only, CF-written only
    // ============================================================================
    match /external_events/{docId} {
      allow read: if isSignedIn();
      allow write: if false; // populated only by the ingestExternalEvents CF
    }
    match /external_country_stats/{docId} {
      allow read: if isSignedIn();
      allow write: if false; // CF-written aggregate
    }
    match /city_coordinates/{docId} {
      allow read: if isSignedIn();
      allow write: if false; // CF-written city → coordinates lookup table
    }
    match /external_events_index/{docId} {
      allow read: if isSignedIn();
      allow write: if false; // CF-written compact shard index for fast loads
    }

    // ============================================================================
    // COMMUNITIES — user-created culture communities (Exchange-style lists)
    // ============================================================================
    // Any signed-in user may create a community and read/join. Content and
    // membership writes are ROLE-GATED: owner/admin manage the community doc,
    // roles, moderation, join-request approval and announcements; ordinary
    // members post chat/tips (unless muted/banned); a user manages only their
    // own membership + join request. (Cloud Functions use the Admin SDK and
    // bypass these rules for their idempotency-flag writes.)
    match /communities/{communityId} {
      function communityData() {
        return get(/databases/$(database)/documents/communities/$(communityId)).data;
      }
      function isCommunityCreator() {
        return isSignedIn() && communityData().createdByUserId == request.auth.uid;
      }
      function myMemberDoc() {
        return get(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid));
      }
      function isMemberOf() {
        return isSignedIn() &&
          exists(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid));
      }
      function myRole() {
        return isMemberOf() ? myMemberDoc().data.role : 'none';
      }
      function isCommunityMod() {
        return isCommunityCreator() || myRole() == 'owner' || myRole() == 'admin' || isAdmin();
      }
      function canPostChat() {
        return isMemberOf() &&
          myMemberDoc().data.get('isBanned', false) == false &&
          myMemberDoc().data.get('isMuted', false) == false;
      }
      // Tips (language/cultural/city) and Announcements may be posted by mods or
      // admin-designated writers only (canWriteTips / canWriteAnnouncements).
      function canWriteTips() {
        return isCommunityMod() ||
          (isMemberOf() && myMemberDoc().data.get('canWriteTips', false) == true);
      }
      function canWriteAnnouncements() {
        return isCommunityMod() ||
          (isMemberOf() && myMemberDoc().data.get('canWriteAnnouncements', false) == true);
      }
      function onlyDenormChanged() {
        // Fields any member's action legitimately touches on the community doc:
        // the join/leave counter and the last-message denormalization written by
        // sendMessage. (Rules/resources/sponsor/promo edits still need a mod.)
        return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['memberCount', 'lastMessagePreview', 'lastActivityAt']);
      }

      // A profile flagged isBusiness is a commerce-only "storefront" identity —
      // it may be searched/browsed but NEVER become a community member (the
      // person joins with their personal identity instead). The one exception
      // is the community's OWN creator, so a business can still own a community
      // it created.
      function memberProfileIsBusiness(uid) {
        return exists(/databases/$(database)/documents/profiles/$(uid)) &&
          get(/databases/$(database)/documents/profiles/$(uid)).data.get('isBusiness', false) == true;
      }
      // A user may always add THEMSELVES (they join with their personal
      // identity — the client shows a confirmation that the storefront is not
      // used). The business exclusion only stops a MOD from adding someone
      // else's storefront identity as a member (except the community creator).
      function memberAddAllowed(memberId) {
        return memberId == request.auth.uid ||
          !memberProfileIsBusiness(memberId) ||
          get(/databases/$(database)/documents/communities/$(communityId)).data.createdByUserId == memberId;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Community edits (rules/resources/sponsor/promo) → owner/admin only,
      // EXCEPT denormalized member-driven fields (memberCount / last message).
      allow update: if isCommunityMod() || (isSignedIn() && onlyDenormChanged());
      allow delete: if isCommunityCreator() || isAdmin();

      // Members: a user manages their OWN membership (join public / leave);
      // owner/admin manage anyone (role, mute/ban, approve, remove). Business
      // (storefront) identities are excluded from membership (except a creator).
      match /members/{memberId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && (memberId == request.auth.uid || isCommunityMod())
          && memberAddAllowed(memberId);
        allow update: if isCommunityMod();
        allow delete: if isSignedIn() && (memberId == request.auth.uid || isCommunityMod());
      }

      // Join requests (private communities): a user creates/cancels their own;
      // owner/admin read & resolve.
      match /join_requests/{userId} {
        allow read: if isCommunityMod();
        allow create: if isSignedIn() && userId == request.auth.uid;
        allow delete: if isCommunityMod() || (isSignedIn() && userId == request.auth.uid);
      }

      // Messages: announcements = mod OR designated announcement-writer; tips
      // (language/cultural/city) = mod OR designated tip-writer (and not muted);
      // plain chat (text/image/…) = any member who isn't muted/banned.
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && (
          (request.resource.data.type == 'announcement' && canWriteAnnouncements()) ||
          (request.resource.data.type in ['language_tip', 'cultural_fact', 'city_tip']
              && canWriteTips() && canPostChat()) ||
          (!(request.resource.data.type in ['announcement', 'language_tip', 'cultural_fact', 'city_tip'])
              && canPostChat())
        );
        allow update, delete: if isCommunityMod();
      }

      // Any other future subcollection: owner/admin only. (Was `read: if
      // isSignedIn()`, which — because Firestore ORs matching rules — overrode
      // the mod-only read on join_requests, letting anyone enumerate who
      // requested to join a private community. members/messages keep their own
      // explicit signed-in read rules above.)
      match /{document=**} {
        allow read, write: if isCommunityMod();
      }
    }

    // ============================================================================
    // BUSINESS (B2B) COLLECTIONS — followers, leads, verification requests
    // ============================================================================
    // Followers of a business. A user manages ONLY their own follower doc under
    // a business; anyone signed in may read (follower lists / counts). The
    // follower fan-out for new events is done server-side by a Cloud Function.
    match /business_followers/{businessId}/followers/{uid} {
      allow read: if isSignedIn();
      allow create, delete: if isOwner(uid);
    }

    // Private mirror index of the businesses a user follows (owned by that user).
    match /user_business_following/{userId}/businesses/{businessId} {
      allow read: if isOwner(userId);
      allow create, delete: if isOwner(userId);
    }

    // Leads a business receives ("Contact" / "Save to my events"). Only the
    // acting user may write their own lead doc; only the business owner reads
    // its own leads list.
    match /business_leads/{businessId}/leads/{uid} {
      allow read: if isOwner(businessId);
      allow create, update: if isOwner(uid);
    }

    // Business verification requests. The owner creates/updates ONLY their own
    // pending request; profile-admins read all and set the approved/rejected
    // status (the badge itself is written on the profile doc).
    match /business_verification_requests/{userId} {
      allow read: if isOwner(userId) || isProfileAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.status == 'pending';
      allow update: if (isOwner(userId) && request.resource.data.status == 'pending')
        || isProfileAdmin();
      allow delete: if false;
    }

    // Business ratings — one 1..5 star doc per rater per business. Anyone
    // signed in may read (avg/count derivation); a user writes ONLY their own
    // rating doc and may NOT rate their own business. The avg/count aggregate
    // is denormalized onto profiles/{businessId}.ratingSum / .ratingCount.
    match /business_ratings/{businessId}/ratings/{raterId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOwner(raterId) && raterId != businessId;
    }

    // ============================================================================
    // EVENTS ("GreenGo Events") — public/private events with RSVP + chat
    // ============================================================================
    match /events/{eventId} {
      function isOrganizer() {
        return isSignedIn() && resource.data.organizerId == request.auth.uid;
      }
      function isEventAttendee() {
        return isSignedIn() &&
          exists(/databases/$(database)/documents/events/$(eventId)/attendees/$(request.auth.uid));
      }

      // Public events readable by anyone signed in; private only by organizer/attendees.
      allow read: if isSignedIn() && (
        resource.data.visibility == 'public' ||
        resource.data.organizerId == request.auth.uid ||
        isEventAttendee()
      );
      // Creator must set themselves as organizer.
      allow create: if isSignedIn()
        && request.resource.data.organizerId == request.auth.uid;
      allow delete: if isOrganizer();
      // Organizer has full update rights. Additionally ANY signed-in user may
      // update ONLY the denormalized RSVP counters (`attendeeCount` and the
      // per-tier `tierGoingCounts` map) — this powers the join / waitlist /
      // auto-promotion transactions that run as the joining/cancelling user.
      allow update: if isOrganizer()
        || (isSignedIn()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['attendeeCount', 'tierGoingCounts', 'viewCount']));

      match /attendees/{uid} {
        function parentOrganizer() {
          return get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid;
        }
        allow read: if isSignedIn();
        // A user manages only their OWN attendee doc — RSVP status, privacy
        // flags and guestCount (QR ticket "bring guests"). The organizer may
        // manage ANY attendee doc, which is what powers QR check-in: flipping
        // checkedIn / checkedInAt for the attendee they just scanned.
        allow write: if isSignedIn()
          && (request.auth.uid == uid || parentOrganizer());
        // Waitlist auto-promotion: when a "going" attendee cancels, the
        // cancelling user promotes the oldest waitlisted attendee. Allow any
        // signed-in user to update ANOTHER attendee doc ONLY to flip status
        // from 'waitlist' to 'going' (they can promote, never demote/delete).
        allow update: if isSignedIn()
          && resource.data.status == 'waitlist'
          && request.resource.data.status == 'going';
      }

      // Likes — one doc per user; likeCount kept current by onEventLikeWrite CF.
      match /likes/{uid} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == uid;
      }

      match /messages/{messageId} {
        function members() {
          return isSignedIn() && (
            exists(/databases/$(database)/documents/events/$(eventId)/attendees/$(request.auth.uid)) ||
            get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid
          );
        }
        function parentOrganizer() {
          return get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid;
        }
        allow read: if members();
        // Normal messages by any member (sender == self); broadcasts by organizer only.
        allow create: if members()
          && request.resource.data.senderId == request.auth.uid
          && (request.resource.data.isBroadcast != true || parentOrganizer());
        allow update, delete: if isSignedIn()
          && resource.data.senderId == request.auth.uid;
      }
    }

    // ============================================================================
    // CATCH-ALL for any other collections used by the app
    // ============================================================================
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdminPanelUser();
    }
  }
}
