<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Allow cleartext HTTP traffic for Firebase Emulators in debug mode -->
    <application
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true">

        <!-- DEBUG/EMULATOR ONLY: disable automatic Firebase data collection and
             auto-init so manual init can point at the local Firebase emulators.
             These MUST NOT ship in release — auto-init being off breaks FCM
             background notification display in production. -->
        <meta-data
            android:name="firebase_crashlytics_collection_enabled"
            android:value="false"
            tools:replace="android:value" />
        <meta-data
            android:name="firebase_analytics_collection_enabled"
            android:value="false"
            tools:replace="android:value" />
        <meta-data
            android:name="firebase_data_collection_default_enabled"
            android:value="false"
            tools:replace="android:value" />
        <provider
            android:name="com.google.firebase.provider.FirebaseInitProvider"
            android:authorities="${applicationId}.firebaseinitprovider"
            android:exported="false"
            tools:node="remove" />
    </application>
</manifest>
